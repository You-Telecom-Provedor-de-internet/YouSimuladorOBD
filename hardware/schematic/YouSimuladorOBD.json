{
  "head": {
    "type": 1,
    "title": "YouSimuladorOBD — Schematic",
    "description": "ESP32 OBD-II Emulator — 7 protocolos, 22 perfis de veículo",
    "version": "2.0.0",
    "exportTime": "2026-04-01",
    "editor": "EasyEDA",
    "editorVersion": "6.5.x"
  },
  "canvas": {
    "unit": "mil",
    "gridSize": "10",
    "viewBox": "-500 -300 3000 2200"
  },

  "note": "Importar em easyeda.com: File > Import > EasyEDA. Ajustar posições se necessário.",

  "blocks": [
    {
      "block": "POWER SUPPLY",
      "note": "OBD Pin16 (+12V) → LM2596 → 5V → ESP32 VIN",
      "connections": [
        { "from": "OBD J1962 Pin16 +12V", "to": "LM2596 IN+" },
        { "from": "OBD J1962 Pin4  GND",  "to": "LM2596 IN-" },
        { "from": "LM2596 OUT+",          "to": "ESP32 VIN (5V)" },
        { "from": "LM2596 OUT-",          "to": "GND" },
        { "from": "ESP32 3V3",            "to": "SN65HVD230 VCC, OLED VCC, KY-040 +" }
      ]
    },
    {
      "block": "CAN BUS — SN65HVD230",
      "connections": [
        { "from": "OBD Pin6  CANH",  "to": "SN65HVD230 CANH (pin7)" },
        { "from": "OBD Pin14 CANL",  "to": "SN65HVD230 CANL (pin6)" },
        { "from": "ESP32 GPIO4",     "to": "SN65HVD230 D/TXD (pin1)" },
        { "from": "ESP32 GPIO5",     "to": "SN65HVD230 R/RXD (pin4)" },
        { "from": "3V3",             "to": "SN65HVD230 VCC (pin3)" },
        { "from": "GND",             "to": "SN65HVD230 GND (pin2)" },
        { "from": "GND",             "to": "SN65HVD230 RS  (pin8)" }
      ]
    },
    {
      "block": "K-LINE — L9637D",
      "connections": [
        { "from": "OBD Pin7 K-Line", "to": "L9637D K (pin2)" },
        { "from": "ESP32 GPIO17",    "to": "L9637D TxD (pin6)" },
        { "from": "ESP32 GPIO16",    "to": "L9637D RxD (pin5)" },
        { "from": "5V",              "to": "L9637D VS (pin7+8)" },
        { "from": "5V",              "to": "L9637D EN (pin3)" },
        { "from": "GND",             "to": "L9637D GND (pin1+4)" }
      ]
    },
    {
      "block": "OLED SSD1306",
      "connections": [
        { "from": "ESP32 GPIO21", "to": "OLED SDA" },
        { "from": "ESP32 GPIO22", "to": "OLED SCL" },
        { "from": "3V3",          "to": "OLED VCC" },
        { "from": "GND",          "to": "OLED GND" }
      ]
    },
    {
      "block": "KY-040 ENCODER",
      "connections": [
        { "from": "ESP32 GPIO12", "to": "KY-040 CLK" },
        { "from": "ESP32 GPIO13", "to": "KY-040 DT" },
        { "from": "ESP32 GPIO15", "to": "KY-040 SW" },
        { "from": "3V3",          "to": "KY-040 + (NÃO usar 5V)" },
        { "from": "GND",          "to": "KY-040 GND" }
      ]
    },
    {
      "block": "BUTTONS (INPUT_PULLUP — outro terminal ao GND)",
      "connections": [
        { "from": "ESP32 GPIO32", "to": "BTN_PREV" },
        { "from": "ESP32 GPIO33", "to": "BTN_NEXT" },
        { "from": "ESP32 GPIO25", "to": "BTN_UP" },
        { "from": "ESP32 GPIO26", "to": "BTN_DOWN" },
        { "from": "ESP32 GPIO27", "to": "BTN_SELECT" },
        { "from": "ESP32 GPIO14", "to": "BTN_PROTOCOL" }
      ]
    },
    {
      "block": "LEDs STATUS (com resistor 330Ω em série → GND)",
      "connections": [
        { "from": "ESP32 GPIO19", "to": "R330Ω → LED Verde   (CAN ativo)" },
        { "from": "ESP32 GPIO18", "to": "R330Ω → LED Amarelo (K-Line ativo)" },
        { "from": "ESP32 GPIO23", "to": "R330Ω → LED Vermelho (TX ativo)" },
        { "from": "ESP32 GPIO2",  "to": "LED Azul builtin (interno ao DevKit)" }
      ]
    },
    {
      "block": "DIP SWITCH (GPIOs 34-36 — somente entrada, sem pull-up interno)",
      "note": "Usar resistor 10kΩ de cada GPIO ao 3V3 (pull-up externo). Chave fechada = GPIO ao GND = LOW.",
      "connections": [
        { "from": "ESP32 GPIO34", "to": "[10kΩ→3V3] + [DIP-1→GND]  bit0 protocolo" },
        { "from": "ESP32 GPIO35", "to": "[10kΩ→3V3] + [DIP-2→GND]  bit1 protocolo" },
        { "from": "ESP32 GPIO36", "to": "[10kΩ→3V3] + [DIP-3→GND]  bit2 protocolo" }
      ]
    }
  ]
}
